# ============================================
# 公众号 Markdown 编辑器 - 配置文件
# ============================================
# 复制本文件为 .env 并填入你的实际配置：
#   cp .env.example .env
#
# 详细说明见 docs/DEPLOY.md
# ============================================

# --- 部署配置 ---

# SSH 连接地址（~/.ssh/config 中的别名 或 root@1.2.3.4）
REMOTE_HOST=your-server

# 服务器上的部署目录
REMOTE_DIR=/opt/md-editor

# 你的域名（不带协议）
PUBLIC_DOMAIN=your-domain.com

# 完整访问地址（带协议）
# 用 HTTPS: https://your-domain.com
# 不用 HTTPS: http://your-domain.com
PUBLIC_URL=https://your-domain.com

# --- 后端配置（分享功能需要） ---

# 分享管理列表页的访问密码，访问 /list 时需要输入
# 自己设一个强密码
LIST_PAGE_PASSWORD=your-secure-password

# 允许跨域请求的来源地址，多个用逗号分隔
# 必须包含你的前端域名，本地开发时加上 localhost
CORS_ORIGINS=https://your-domain.com,http://localhost:8080,http://localhost:3000

# --- Nginx / SSL ---

# SSL 证书所在目录（Let's Encrypt 格式）
# 申请后通常在 /etc/letsencrypt/live/你的域名/
# 不用 HTTPS 可以留空（deploy.sh 会生成纯 HTTP Nginx 配置）
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com
